{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uap-spec.io/schema/v1/agent-did-document.json",
  "title": "UAP AgentDID Document",
  "description": "UAP Agent 去中心化身份文档规范",
  "type": "object",
  "required": ["@context", "id", "created", "service", "verificationMethod"],
  "properties": {
    "@context": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "default": ["https://www.w3.org/ns/did/v1", "https://uap-spec.io/context/v1"]
    },
    "id": {
      "type": "string",
      "pattern": "^did:uap:[a-z0-9-]+:[a-z0-9-]+(:[a-z0-9-]+)?$",
      "description": "AgentDID 唯一标识符",
      "examples": ["did:uap:openwen:yijing-agent"]
    },
    "created": {"type": "string", "format": "date-time"},
    "updated": {"type": "string", "format": "date-time"},
    "controller": {
      "type": "string",
      "pattern": "^did:uap:",
      "description": "控制者 DID，通常是父级协调 Agent"
    },
    "service": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "serviceEndpoint"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string", "enum": ["UAPEndpoint", "UAPLiteEndpoint"]},
          "serviceEndpoint": {"type": "string", "format": "uri"},
          "transportProtocols": {
            "type": "array",
            "items": {"type": "string", "enum": ["http2", "websocket", "grpc", "mqtt"]}
          }
        }
      }
    },
    "verificationMethod": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "publicKeyMultibase"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string", "enum": ["Ed25519VerificationKey2020", "X25519KeyAgreementKey2020"]},
          "publicKeyMultibase": {"type": "string"}
        }
      }
    },
    "authentication": {"type": "array", "items": {"type": "string"}},
    "capabilityDelegation": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
