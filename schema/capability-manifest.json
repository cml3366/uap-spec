{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uap-spec.io/schema/v1/capability-manifest.json",
  "title": "UAP Capability Manifest",
  "description": "UAP Agent 能力清单，暴露于 /.well-known/uap",
  "type": "object",
  "required": ["uap_version", "agent", "capabilities"],
  "properties": {
    "uap_version": {"type": "string", "examples": ["1.0"]},
    "agent": {
      "type": "object",
      "required": ["did", "name", "version", "access_tier", "endpoint"],
      "properties": {
        "did": {"type": "string", "pattern": "^did:uap:"},
        "name": {"type": "string"},
        "description": {"type": "string"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+"},
        "access_tier": {"type": "string", "enum": ["open", "authenticated", "private"]},
        "endpoint": {"type": "string", "format": "uri"},
        "icon_url": {"type": "string", "format": "uri"},
        "tags": {"type": "array", "items": {"type": "string"}}
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "version"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*\\.[a-z][a-z0-9._]*$",
            "description": "能力 ID，格式：domain.capability_name",
            "examples": ["yijing.interpret", "openwen.classics.search"]
          },
          "name": {"type": "string"},
          "description": {"type": "string"},
          "version": {"type": "string"},
          "access_tier": {"type": "string", "enum": ["open", "authenticated", "private"]},
          "input_schema": {"type": "string", "description": "输入 Schema 引用或内联"},
          "output_schema": {"type": "string", "description": "输出 Schema 引用或内联"},
          "rate_limit": {
            "type": "object",
            "properties": {
              "requests_per_minute": {"type": "integer"},
              "requests_per_day": {"type": "integer"}
            }
          },
          "avg_latency_ms": {"type": "integer"},
          "required_agents": {
            "type": "array",
            "items": {"type": "string", "pattern": "^did:uap:"},
            "description": "此能力依赖的其他 Agent DID"
          },
          "deprecated": {"type": "boolean", "default": false},
          "deprecated_message": {"type": "string"}
        }
      }
    },
    "trust": {
      "type": "object",
      "properties": {
        "public_key": {"type": "string"},
        "cert_fingerprint": {"type": "string"}
      }
    }
  }
}
